# spike/.env 로 복사 후 키 입력 (이 폴더의 .env는 gitignore 대상)
GEMINI_API_KEY=
# Vertex(GCP 프로젝트 키, AQ.* 형식)면 아래 두 줄 입력. AI Studio 키(AIza*)면 비워둠.
VERTEX_PROJECT=
VERTEX_LOCATION=global
# 모델 교체는 여기서만 (ai_pipeline_spec §6과 동일 키)
MODEL_ROUTING_IMAGE_HIGH=gemini-3-pro-image
# --provider openai 용 (베이스 생성 비교 실험): platform.openai.com API 키
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
