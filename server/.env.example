# Wearless Studio API — Phase 0 환경 변수
# Railway 서비스 Variables에 동일 키로 등록한다.

APP_ENV=dev                      # dev | production
SUPABASE_URL=                    # https://<project-ref>.supabase.co
# SUPABASE_JWKS_URL=             # 기본값: $SUPABASE_URL/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_AUDIENCE=authenticated
CORS_ORIGINS=http://localhost:5173,https://ai.wearless.kr

# DB 직접 연결 (마이그레이션 적용 — Session pooler URI, 비밀번호 percent-encode)
DATABASE_URL=                    # postgresql://postgres.<ref>:<pw>@...pooler.supabase.com:5432/postgres
# Supabase API 키 (대시보드 Settings → API). Phase 1 서버 쓰기에 필요.
SUPABASE_ANON_KEY=               # publishable — 공개 가능
SUPABASE_SERVICE_ROLE_KEY=       # secret — 서버 전용, 절대 프론트/채팅 노출 금지

# R2 (Cloudflare, S3 호환) — 자산 저장 (§3). secret 등급, 서버 전용(Railway). 프론트(Vercel) 금지.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=            # 한 번만 표시됨 — 잘 저장
R2_BUCKET=                       # 예: wearless-assets
R2_ENDPOINT=                     # https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE=                  # 커스텀 도메인 예: https://images.wearless.kr (없으면 signed GET 폴백)
