# Wearless Studio API вҖ” Phase 0 нҷҳкІҪ ліҖмҲҳ
# Railway м„ңл№„мҠӨ Variablesм—җ лҸҷмқј нӮӨлЎң л“ұлЎқн•ңлӢӨ.

APP_ENV=dev                      # dev | production вҖ” productionм—җм„ң AUTH_DEV_USER_ID л¬ҙмӢң
SUPABASE_URL=                    # https://<project-ref>.supabase.co
# SUPABASE_JWKS_URL=             # кё°ліёк°’: $SUPABASE_URL/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_AUDIENCE=authenticated
CORS_ORIGINS=http://localhost:5173,https://ai.wearless.kr
# AUTH_DEV_USER_ID=              # dev н•ңм • мқөлӘ… н”Ңлһҳк·ё (В§9 вҖ” Phase 1к№Ңм§Җл§Ң)

# DB м§Ғм ‘ м—°кІ° (л§Ҳмқҙк·ёл Ҳмқҙм…ҳ м Ғмҡ© вҖ” Session pooler URI, л№„л°ҖлІҲнҳё percent-encode)
DATABASE_URL=                    # postgresql://postgres.<ref>:<pw>@...pooler.supabase.com:5432/postgres
# Supabase API нӮӨ (лҢҖмӢңліҙл“ң Settings вҶ’ API). Phase 1 м„ңлІ„ м“°кё°м—җ н•„мҡ”.
SUPABASE_ANON_KEY=               # publishable вҖ” кіөк°ң к°ҖлҠҘ
SUPABASE_SERVICE_ROLE_KEY=       # secret вҖ” м„ңлІ„ м „мҡ©, м ҲлҢҖ н”„лЎ нҠё/мұ„нҢ… л…ём¶ң кёҲм§Җ
