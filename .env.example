# Vite 프론트 설정 — .env.local 로 복사해서 사용
# API 모드: mock(기본) | http — http 면 httpAdapter 에 구현된 함수만 실서버 사용 (plan §8)
VITE_API_MODE=mock
# http 모드의 FastAPI 베이스 URL
VITE_API_BASE_URL=https://api.wearless.kr
# 배경-only 생성예시 파일럿. 기본 false; 품질 게이트 통과 전 production 활성화 금지.
VITE_GENEXAMPLE_BG_ENABLED=false

# Supabase 인증 (프론트는 인증만 직접 접근 — plan §1). 둘 다 공개 가능한 값.
# ⚠️ service_role 키·DATABASE_URL 은 프론트(VITE_*) 에 절대 넣지 말 것 — 번들에 노출됨.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
